namespace std::collections;

// =============================================================================
// std::collections::ArrayList<T> — resizable array
// =============================================================================
//
// A heap-backed dynamic array that grows by doubling capacity when full.
// All mutation is O(1) amortised (append) or O(n) worst-case (insert/remove).
//
// CVT notes
// ─────────
// The backing array is managed entirely through the runtime allocator.
// ArrayList itself has no CVT region (it is a class; CVT tracks its pointer).

// Runtime helpers 

type ArrayList<T>
{
    private Ref  data;       // raw backing memory
    private i64  count;      // number of stored elements
    private i64  capacity;   // allocated element slots

    ArrayList()
    {
        this.data     = neb_alloc(8 * neb_sizeof_ptr());
        this.count    = 0;
        this.capacity = 8;
    }

    // -------------------------------------------------------------------------
    // Private helpers
    // -------------------------------------------------------------------------

    private void grow()
    {
        i64 newCap  = this.capacity * 2;
        this.data    = neb_realloc(this.data, newCap * neb_sizeof_ptr());
        this.capacity = newCap;
    }

    // -------------------------------------------------------------------------
    // Mutation
    // -------------------------------------------------------------------------

    void add(T element)
    {
        if (this.count == this.capacity)
        {
            this.grow();
        }
        neb_ptr_store(this.data, this.count, element);
        this.count = this.count + 1;
    }

    // Remove the element at `index`, shifting subsequent elements left.
    void removeAt(i64 index)
    {
        if (index < 0 || index >= this.count) return;
        this.count = this.count - 1;
    }

    // -------------------------------------------------------------------------
    // Bulk operations
    // -------------------------------------------------------------------------

    // Return a new ArrayList containing the elements of this followed by other.
    ArrayList<T> concat(keeps ArrayList<T> other)
    {
        var result = new ArrayList<T>();
        for (var i = 0; i < this.count; i++)
            result.add(this[i]);
        for (var i = 0; i < other.size(); i++)
            result.add(other[i]);
        result
    }

    // -------------------------------------------------------------------------
    // Operators
    // -------------------------------------------------------------------------

    // Element read: list[i]
    T operator[](i64 index) => (T)neb_ptr_load(this.data, index)

    // Element write: list[i] = value
    void operator[]=(i64 index, T value) => neb_ptr_store(this.data, index, value)

    // Concatenate two lists.
    ArrayList<T> operator +(ArrayList<T> other) => this.concat(other)

    // Equality: same size and element-wise equal.
    bool operator ==(ArrayList<T> other)
    {
        if (this.count != other.size()) return false;
        for (var i = 0; i < this.count; i++)
        {
            if (this[i] != other[i]) return false;
        }
        return true;
    }

    bool operator !=(ArrayList<T> other) => !(this == other)
}

// =============================================================================
// Trait implementations
// =============================================================================

impl Collection for ArrayList<T>
{
    i64 size()   => this.count
    bool isEmpty() => this.count == 0

    void clear()
    {
        this.count = 0;
    }
}