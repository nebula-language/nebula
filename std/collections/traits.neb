namespace std::collections;

// =============================================================================
// std::collections::traits — core collection contracts
// =============================================================================

// -----------------------------------------------------------------------------
// Hashable — anything that can produce a deterministic hash code.
// Equal values must always produce equal hash codes.
// -----------------------------------------------------------------------------

trait Hashable
{
    i64 hashCode();
}

// -----------------------------------------------------------------------------
// Equatable — structural value equality (distinct from reference identity).
// -----------------------------------------------------------------------------

trait Equatable
{
    bool equals(Equatable other);
}

// -----------------------------------------------------------------------------
// Collection — the minimal read-only contract shared by all collections.
// -----------------------------------------------------------------------------

trait Collection
{
    i64  size();
    bool isEmpty() => this.size() == 0
    void clear();
}

// -----------------------------------------------------------------------------
// Indexable — integer-indexed random access.
// -----------------------------------------------------------------------------

trait Indexable
{
    i64 size();
}
